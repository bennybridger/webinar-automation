# Brevo (email sends)
BREVO_API_KEY=your-brevo-api-key-here

# Google Cloud (Sheets + Calendar)
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/path/to/your/service-account.json
GOOGLE_SHEET_ID=your-google-sheet-id-from-url
GOOGLE_CALENDAR_ID=your-email@gmail.com

# Anthropic (Claude API for email content generation)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# Zoom (meeting creation via Server-to-Server OAuth)
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# HubSpot (landing page creation)
HUBSPOT_ACCESS_TOKEN=pat-xx-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Sender identity (used in Brevo sends)
SENDER_EMAIL=you@example.com
SENDER_NAME=Your Name
